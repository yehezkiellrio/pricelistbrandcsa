# Optional: website works with bundled Excel data without these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hanya untuk kompatibilitas project Supabase lama. Tidak perlu diisi bila
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY sudah tersedia.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only needed by `npm run import:supabase` locally. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=
